const students = [
  { name: "Иван", grade: 4 },
  { name: "Анна", grade: 5 },
  { name: "Петр", grade: 3 },
  { name: "Елена", grade: 5 }
];

// Ваш код здесь:

const excellentStudents = students
  .filter((student) => student.grade === 5) // Шаг 1: оставили только отличников
  .map((student) => student.name);          // Шаг 2: из оставшихся достали имена

console.log("Имена отличников: ", excellentStudents);
